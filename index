    html += '<thead><tr>';
    html += '<th class="player-col player-col-empty">Spieler</th>';

    allMatches.forEach(function(m) {
      const result = state.results[m.id];
      const locked = isTippLocked(m);
      let dateStr = '';
      if (m.kickoff) {
        const d = new Date(m.kickoff);
        dateStr = d.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit' });
      } else {
        dateStr = 'TBD';
      }

      html += '<th>';
      html += '<div class="th-badges">' + teamBadge(m.teamA, 'sm') + ' <span class="th-vs">vs</span> ' + teamBadge(m.teamB, 'sm') + '</div>';
      html += '<div class="th-date">' + dateStr + (locked ? ' 🔒' : '') + '</div>';
      if (result) {
        html += '<div class="th-result">' + result.a + ' : ' + result.b + '</div>';
      } else {
        html += '<div class="th-result pending">offen</div>';
      }
      html += '</th>';
    });
    html += '</tr></thead><tbody>';

    // Zeilen pro User
    rankedUsers.forEach(function(u) {
      const isMe = u.id === currentUserId;
      html += '<tr class="' + (isMe ? 'me-row' : '') + '">';
      html += '<td class="player-cell ' + (isMe ? 'me' : '') + '">';
      html += escapeHtml(u.name) + (isMe ? ' (du)' : '');
      html += '<span class="player-points">' + u.points + ' Punkte</span>';
      html += '</td>';

      allMatches.forEach(function(m) {
        const tipp = state.tipps[m.id] && state.tipps[m.id][u.id];
        const result = state.results[m.id];
        const locked = isTippLocked(m);

        if (!tipp) {
          // Kein Tipp abgegeben
          let cellHtml = '<td class="tipp-none">';
          cellHtml += locked ? '—' : '· · ·';
          if (isAdmin) {
            cellHtml += '<button class="admin-edit is-admin" data-admin-edit-tipp="' + m.id + '" data-admin-edit-user="' + u.id + '" title="Tipp für User hinzufügen">+</button>';
          }
          cellHtml += '</td>';
          html += cellHtml;
        } else {
          const pts = result ? calcPoints(tipp, result) : null;
          let cls = 'tipp-none';
          if (pts === 3) cls = 'tipp-3';
          else if (pts === 2) cls = 'tipp-2';
          else if (pts === 1) cls = 'tipp-1';
          else if (pts === 0 && result) cls = 'tipp-0';
          else cls = locked ? 'tipp-locked' : '';

          let cellHtml = '<td class="' + cls + '">';
          cellHtml += tipp.a + ':' + tipp.b;
          if (pts !== null) {
            cellHtml += '<span class="tipp-pts">' + pts + 'P</span>';
          }
          if (isAdmin) {
            cellHtml += '<button class="admin-edit is-admin" data-admin-edit-tipp="' + m.id + '" data-admin-edit-user="' + u.id + '" title="Tipp bearbeiten">✎</button>';
          }
          cellHtml += '</td>';
