  function shortName(name) {
    // Kürzt lange Teamnamen für Tabellenkopf
    const short = {
      'Brasilien': 'BRA',
      'Marokko': 'MAR',
      'Schottland': 'SCO',
      'Haiti': 'HAI'
    };
    if (short[name]) return short[name];
    if (name.length > 4) return name.slice(0, 3).toUpperCase();
    return name.toUpperCase();
  }

  function openAdminTippEditor(matchId, userId) {
    const userName = state.users[userId] ? state.users[userId].name : '?';
    const existingTipp = state.tipps[matchId] && state.tipps[matchId][userId];

    const allMatches = getAllMoroccoMatches();
    const match = allMatches.find(function(m) { return m.id === matchId; });
    if (!match) return;

    const matchLabel = match.teamA.name + ' vs ' + match.teamB.name;

    const input = prompt(
      '👑 Admin: Tipp von "' + userName + '" für ' + matchLabel + '\n\n' +
      'Format: Tore_A:Tore_B (z.B. 2:1)\n' +
      'Leer lassen + OK zum Löschen',
      existingTipp ? existingTipp.a + ':' + existingTipp.b : ''
    );

    if (input === null) return; // Abbrechen

    if (input.trim() === '') {
      // Löschen
      if (state.tipps[matchId] && state.tipps[matchId][userId]) {
        delete state.tipps[matchId][userId];
        if (Object.keys(state.tipps[matchId]).length === 0) delete state.tipps[matchId];
        saveAndSync();
        showToast('Tipp gelöscht');
      }
      return;
    }

    const match2 = input.match(/^\s*(\d+)\s*[:\-\s]\s*(\d+)\s*$/);
    if (!match2) { showToast('Format: 2:1', true); return; }

    const a = parseInt(match2[1], 10);
    const b = parseInt(match2[2], 10);
    if (isNaN(a) || isNaN(b) || a < 0 || b < 0 || a > 20 || b > 20) {
      showToast('Ungültiges Ergebnis', true);
      return;
    }

    if (!state.tipps[matchId]) state.tipps[matchId] = {};
    state.tipps[matchId][userId] = { a: a, b: b, ts: Date.now(), editedByAdmin: true };
    saveAndSync();
    showToast('Tipp gespeichert');
  }

