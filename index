      return;
    }

    // Sortiere User nach Gesamtpunkten absteigend (führender oben)
    const rankedUsers = userIds.map(function(uid) {
      const stats = calculateUserPoints(uid);
      return { id: uid, name: state.users[uid].name, points: stats.points };
    }).sort(function(a, b) { return b.points - a.points || a.name.localeCompare(b.name); });

    // Header bauen
