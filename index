  // ─── PUNKTE-BERECHNUNG ─────────────────────────────────────
  // ═══════════════════════════════════════════════════════════

  function calcPoints(tipp, result) {
    if (!tipp || !result) return 0;
    // 3 P: exakt
    if (tipp.a === result.a && tipp.b === result.b) return 3;
    // 2 P: Tordifferenz gleich (und kein Remis-Mismatch)
    const tDiff = tipp.a - tipp.b;
    const rDiff = result.a - result.b;
    if (tDiff === rDiff && tDiff !== 0) return 2;
    // 1 P: Tendenz
    if (Math.sign(tDiff) === Math.sign(rDiff)) return 1;
    return 0;
  }

  function calculateUserPoints(userId) {
    let total = 0;
    let count = 0;
    Object.keys(state.tipps).forEach(function(matchId) {
      const userTipps = state.tipps[matchId];
      if (userTipps[userId] && state.results[matchId]) {
        total += calcPoints(userTipps[userId], state.results[matchId]);
        count++;
      }
    });
    return { points: total, evaluated: count };
  }

