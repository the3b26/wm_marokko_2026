  function renderBracketMatch(matchTemplate, roundKey) {
    const resolved = resolveBracketTeams(matchTemplate);
    const koData = state.bracket.ko[matchTemplate.id];

    const teamA = resolved.teamA ? codeToTeam(resolved.teamA) : null;
    const teamB = resolved.teamB ? codeToTeam(resolved.teamB) : null;

    const hasMorocco = isMorocco(resolved.teamA) || isMorocco(resolved.teamB);
    const moroccoAdvanced = koData && koData.winner && isMorocco(koData.winner);

    let cardClass = 'br-match';
    if (hasMorocco) cardClass += ' has-morocco';
    if (moroccoAdvanced) cardClass += ' morocco-advanced';

    let html = '<div class="' + cardClass + '" data-br-match="' + matchTemplate.id + '" data-br-round="' + roundKey + '">';
    html += '<div class="br-info">' + escapeHtml(matchTemplate.label || '');
    if (koData && koData.kickoff) {
      const d = new Date(koData.kickoff);
      const dStr = d.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit' });
      const tStr = d.toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
      html += ' · <span style="color:var(--gold);">' + dStr + ' ' + tStr + '</span>';
    }
    html += '</div>';

    html += renderBracketTeam(teamA, resolved.teamA, koData, 'a');
    html += '<div class="br-divider"></div>';
    html += renderBracketTeam(teamB, resolved.teamB, koData, 'b');

    html += '</div>';
    return html;
  }

  function renderBracketTeam(team, teamCode, koData, side) {
    if (!team) {
      return '<div class="br-team" style="color:var(--text-muted); font-size:0.7rem;">— offen —</div>';
    }
    const isMar = isMorocco(teamCode);
    let cls = 'br-team';
    if (isMar) cls += ' morocco';

    let score = '';
    if (koData && (koData.scoreA !== undefined || koData.scoreB !== undefined)) {
      score = side === 'a' ? (koData.scoreA !== undefined ? koData.scoreA : '') : (koData.scoreB !== undefined ? koData.scoreB : '');
      if (koData.winner && koData.winner === teamCode) cls += ' winner';
      else if (koData.winner) cls += ' loser';
    }

    return '<div class="' + cls + '">' +
      '<span class="br-team-name">' + teamBadge(team, 'sm') + ' ' + escapeHtml(team.name) + '</span>' +
      '<span class="br-team-score">' + score + '</span>' +
    '</div>';
  }

  // Bracket Modal
  let currentBracketMatch = null;
  function openBracketModal(matchId, roundKey) {
    const allRounds = ['round_of_16', 'quarter', 'semi', 'final'];
    let matchTemplate = null;
    allRounds.forEach(function(r) {
      const found = BRACKET_TEMPLATE[r].find(function(m) { return m.id === matchId; });
      if (found) matchTemplate = found;
    });
    if (!matchTemplate) return;

    const resolved = resolveBracketTeams(matchTemplate);
    // Auch bei unbekannten Teams Modal öffnen — Admin kann dann nur die Anpfiff-Zeit eintragen
    const teamACode = resolved.teamA || (matchTemplate.teamA || 'TBD');
    const teamBCode = resolved.teamB || (matchTemplate.teamB || 'TBD');

    // Prüfen ob beide Teams konkrete 3-Buchstaben-Codes sind
    const teamsAreFinal = /^[A-Z]{3}$/.test(teamACode) && /^[A-Z]{3}$/.test(teamBCode);

    const teamA = codeToTeam(teamACode);
    const teamB = codeToTeam(teamBCode);
    currentBracketMatch = { id: matchId, teamA: teamACode, teamB: teamBCode, template: matchTemplate, teamsAreFinal: teamsAreFinal };

    document.getElementById('bracket-modal-subtitle').textContent = matchTemplate.label;
    document.getElementById('bracket-team-a').innerHTML = teamBadge(teamA, 'sm') + ' ' + escapeHtml(teamA.name);
    document.getElementById('bracket-team-b').innerHTML = teamBadge(teamB, 'sm') + ' ' + escapeHtml(teamB.name);

    const existing = state.bracket.ko[matchId];

    // Score-Felder: nur aktivieren wenn Teams feststehen
    const scoreA = document.getElementById('bracket-score-a');
    const scoreB = document.getElementById('bracket-score-b');
    scoreA.disabled = !teamsAreFinal;
    scoreB.disabled = !teamsAreFinal;
    scoreA.value = existing ? (existing.scoreA !== undefined ? existing.scoreA : '') : '';
    scoreB.value = existing ? (existing.scoreB !== undefined ? existing.scoreB : '') : '';

    // Hinweis-Box bei nicht-feststehenden Teams
    const scoreHint = document.getElementById('bracket-score-hint');
    if (scoreHint) scoreHint.remove();
    if (!teamsAreFinal) {
      const hint = document.createElement('div');
      hint.id = 'bracket-score-hint';
      hint.style.cssText = 'background:rgba(255,71,87,0.1); border:1px solid rgba(255,71,87,0.3); color:var(--text); padding:8px 10px; border-radius:8px; font-size:0.78rem; margin-bottom:12px; text-align:center; line-height:1.4;';
      hint.innerHTML = '⏳ Teams stehen noch nicht fest. Du kannst nur die <strong>Anpfiff-Zeit</strong> eintragen. Das Ergebnis kannst du nach der vorherigen Runde setzen.';
      const kickoffField = document.getElementById('bracket-kickoff').parentNode;
      kickoffField.parentNode.insertBefore(hint, kickoffField.nextSibling);
    }

    // Kickoff-Zeit befüllen (Format für datetime-local: YYYY-MM-DDTHH:mm)
    const kickoffInput = document.getElementById('bracket-kickoff');
    if (existing && existing.kickoff) {
      const d = new Date(existing.kickoff);
      const pad = function(n) { return String(n).padStart(2, '0'); };
      const local = d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) + 'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
      kickoffInput.value = local;
    } else {
      kickoffInput.value = '';
    }

    // Sieger-Picker (für Unentschieden) — nur wenn Teams feststehen
    document.getElementById('bracket-pick-a').innerHTML = teamBadge(teamA, 'sm') + ' ' + escapeHtml(teamA.name);
    document.getElementById('bracket-pick-b').innerHTML = teamBadge(teamB, 'sm') + ' ' + escapeHtml(teamB.name);
    document.getElementById('bracket-pick-a').setAttribute('data-pick', teamACode);
    document.getElementById('bracket-pick-b').setAttribute('data-pick', teamBCode);
    document.getElementById('bracket-pick-a').classList.toggle('primary', existing && existing.winner === teamACode);
    document.getElementById('bracket-pick-a').classList.toggle('ghost', !(existing && existing.winner === teamACode));
    document.getElementById('bracket-pick-b').classList.toggle('primary', existing && existing.winner === teamBCode);
    document.getElementById('bracket-pick-b').classList.toggle('ghost', !(existing && existing.winner === teamBCode));

    updateBracketWinnerVisibility();
    document.getElementById('modal-bracket').classList.add('show');
  }

  function updateBracketWinnerVisibility() {
    const a = parseInt(document.getElementById('bracket-score-a').value, 10);
    const b = parseInt(document.getElementById('bracket-score-b').value, 10);
    const isDraw = !isNaN(a) && !isNaN(b) && a === b;
    document.getElementById('bracket-winner-select').style.display = isDraw ? '' : 'none';
  }

  ['bracket-score-a', 'bracket-score-b'].forEach(function(id) {
    document.getElementById(id).addEventListener('input', updateBracketWinnerVisibility);
  });

  document.getElementById('bracket-pick-a').addEventListener('click', function() {
    document.getElementById('bracket-pick-a').classList.add('primary');
    document.getElementById('bracket-pick-a').classList.remove('ghost');
    document.getElementById('bracket-pick-b').classList.remove('primary');
    document.getElementById('bracket-pick-b').classList.add('ghost');
  });
  document.getElementById('bracket-pick-b').addEventListener('click', function() {
    document.getElementById('bracket-pick-b').classList.add('primary');
    document.getElementById('bracket-pick-b').classList.remove('ghost');
    document.getElementById('bracket-pick-a').classList.remove('primary');
    document.getElementById('bracket-pick-a').classList.add('ghost');
  });

  document.getElementById('btn-bracket-cancel').addEventListener('click', function() {
    document.getElementById('modal-bracket').classList.remove('show');
  });

  document.getElementById('btn-bracket-clear').addEventListener('click', async function() {
    if (!currentBracketMatch) return;
    delete state.bracket.ko[currentBracketMatch.id];
    document.getElementById('modal-bracket').classList.remove('show');
    await saveAndSync();
    showToast('Spiel gelöscht');
  });

  document.getElementById('btn-bracket-save').addEventListener('click', async function() {
    if (!currentBracketMatch) return;

    const aRaw = document.getElementById('bracket-score-a').value.trim();
    const bRaw = document.getElementById('bracket-score-b').value.trim();
    const kickoffRaw = document.getElementById('bracket-kickoff').value;

    // Speichern erlaubt wenn entweder Anpfiff-Zeit ODER Ergebnis eingegeben
    const hasScore = aRaw !== '' && bRaw !== '';
    const hasKickoff = kickoffRaw !== '';

    if (!hasScore && !hasKickoff) {
      showToast('Bitte Anpfiff-Zeit oder Ergebnis eingeben', true);
      return;
    }

    // Existierende Daten holen (damit man nicht alles überschreibt)
    const existing = state.bracket.ko[currentBracketMatch.id] || {};
    const koData = {
      teamA: currentBracketMatch.teamA,
      teamB: currentBracketMatch.teamB,
      ts: Date.now()
    };

    // Kickoff übernehmen wenn eingegeben, sonst beibehalten
    if (hasKickoff) {
      koData.kickoff = new Date(kickoffRaw).toISOString();
    } else if (existing.kickoff) {
      koData.kickoff = existing.kickoff;
    }

    // Ergebnis übernehmen wenn eingegeben
    if (hasScore) {
      const a = parseInt(aRaw, 10);
      const b = parseInt(bRaw, 10);
      if (isNaN(a) || isNaN(b) || a < 0 || b < 0) { showToast('Ungültiges Ergebnis', true); return; }

      let winner = null;
      if (a > b) winner = currentBracketMatch.teamA;
      else if (b > a) winner = currentBracketMatch.teamB;
      else {
        const pickedA = document.getElementById('bracket-pick-a').classList.contains('primary');
        const pickedB = document.getElementById('bracket-pick-b').classList.contains('primary');
        if (!pickedA && !pickedB) { showToast('Bei Unentschieden Sieger wählen!', true); return; }
        winner = pickedA ? currentBracketMatch.teamA : currentBracketMatch.teamB;
      }
      koData.scoreA = a;
      koData.scoreB = b;
      koData.winner = winner;
    } else if (existing.scoreA !== undefined) {
      // Bestehende Ergebnisse beibehalten
      koData.scoreA = existing.scoreA;
      koData.scoreB = existing.scoreB;
      koData.winner = existing.winner;
    }

    state.bracket.ko[currentBracketMatch.id] = koData;
    document.getElementById('modal-bracket').classList.remove('show');
    await saveAndSync();
    showToast('Gespeichert');
  });

  // ═══════════════════════════════════════════════════════════
  // ─── SHARE ─────────────────────────────────────────────────
  // ═══════════════════════════════════════════════════════════

  document.getElementById('btn-share-link').addEventListener('click', function() {
    const text = '🇲🇦 Sabraoui & Co. — Familien-Tippspiel WM 2026, komm mit, tippe Marokkos Spiele! ' + window.location.href;
    if (navigator.share) {
      navigator.share({ title: 'Sabraoui & Co. WM 2026', text: text, url: window.location.href }).catch(function() {});
    } else if (navigator.clipboard) {
      navigator.clipboard.writeText(window.location.href).then(function() {
        showToast('Link kopiert!');
      });
    } else {
      showToast('Teilen nicht verfügbar');
    }
  });

  // ═══════════════════════════════════════════════════════════
  // ─── UTILITIES ─────────────────────────────────────────────
  // ═══════════════════════════════════════════════════════════

  function escapeHtml(str) {
    return String(str || '').replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  let toastTimer = null;
  function showToast(msg, isError) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.toggle('error', !!isError);
    t.classList.add('show');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(function() { t.classList.remove('show'); }, 1800);
  }

  // ═══════════════════════════════════════════════════════════
  // ─── RENDER ALL ────────────────────────────────────────────
  // ═══════════════════════════════════════════════════════════

  function renderAll() {
    renderSchedule();
    renderAllTipps();
    renderLeaderboard();
    renderBracket();
  }

  // ═══════════════════════════════════════════════════════════
  // ─── INIT ──────────────────────────────────────────────────
  // ═══════════════════════════════════════════════════════════

  async function init() {
    // Setup-Banner anzeigen falls JSONBin nicht konfiguriert
    if (!hasJsonbin()) {
      document.getElementById('setup-banner').style.display = '';
      setSyncStatus('error', 'LOKAL');
    } else {
      setSyncStatus('syncing', 'VERBINDET…');
      await fetchFromCloud();
    }

    initUser();
    renderAll();

    // Live-Updates jede Sekunde für Countdown / Lock-Status
    setInterval(function() {
      // Nur Spielplan re-rendern wenn Status sich ändern könnte
      renderSchedule();
    }, 30000);

    if (hasJsonbin()) startPolling();
  }

  init();
})();
</script>
</body>
</html>