  // Erzeugt das Team-Badge mit SVG-Flagge + Kürzel
  function teamBadge(team, size) {
    const sm = size === 'sm' ? ' sm' : '';
    const code = team.code || team.short;
    let cls = 'country-badge' + sm;
    if (code === 'MAR') cls += ' is-morocco';
    else if (!/^[A-Z]{3}$/.test(code)) cls += ' placeholder';

    const flagSvg = COUNTRY_FLAGS[code] || '';
    const flagHtml = flagSvg ? '<span class="cb-flag">' + flagSvg + '</span>' : '';
    return '<span class="' + cls + '">' + flagHtml + '<span class="cb-code">' + escapeHtml(team.short || code) + '</span></span>';
  }

  function resolveBracketTeams(matchTemplate) {
    // Liefert die aktuellen Teams für ein Bracket-Match (kann Platzhalter sein)
    const resolved = { teamA: null, teamB: null };

    // Für Achtelfinale: aus Gruppen-Platzierungen
    if (matchTemplate.teamA && matchTemplate.teamB) {
      // Format: "A1", "B2" etc.
      resolved.teamA = resolveGroupPlace(matchTemplate.teamA);
      resolved.teamB = resolveGroupPlace(matchTemplate.teamB);
    } else if (matchTemplate.sourceA && matchTemplate.sourceB) {
      // Sieger aus vorherigem Spiel
      const winnerA = state.bracket.ko[matchTemplate.sourceA];
      const winnerB = state.bracket.ko[matchTemplate.sourceB];
      resolved.teamA = winnerA && winnerA.winner ? winnerA.winner : null;
      resolved.teamB = winnerB && winnerB.winner ? winnerB.winner : null;
    }
    return resolved;
  }

  function resolveGroupPlace(place) {
    // "C1" → Sieger der Gruppe C, falls Admin eingetragen
    const groupKey = place.charAt(0);
    const rank = place.charAt(1);
    const group = state.bracket.groups[groupKey];
    if (group && group[rank]) return group[rank];
    return place; // Bleibt Platzhalter
  }

  function formatKickoff(iso) {
    const d = new Date(iso);
    const dateStr = d.toLocaleDateString('de-DE', { weekday: 'short', day: '2-digit', month: 'short' });
    const timeStr = d.toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
    return dateStr + ' · ' + timeStr;
  }

  function getMatchStatus(match) {
    if (state.results[match.id]) return 'finished';
    if (!match.kickoff) return 'upcoming';
    const now = Date.now();
    const ko = new Date(match.kickoff).getTime();
    if (now >= ko && now < ko + 2.5 * 60 * 60 * 1000) return 'live';
    if (now >= ko) return 'finished_no_result';
    return 'upcoming';
  }

  function isTippLocked(match) {
    if (!match.kickoff) return false;
    const ko = new Date(match.kickoff).getTime();
    // Für K.O.-Spiele: 30 Minuten vor Anpfiff sperren
    // Für Gruppenphase: erst bei Anpfiff sperren
    const lockTime = match.isKo ? ko - 30 * 60 * 1000 : ko;
    return Date.now() >= lockTime;
  }

  function getLockHint(match) {
    // Liefert einen Hint-Text wann der Tipp sperrt
    if (!match.kickoff) return '';
    if (match.isKo) {
      return 'Tipps werden 30 Min vor Anpfiff gesperrt';
    }
    return 'Tipps werden bei Anpfiff gesperrt';
  }

  function renderSchedule() {
    const container = document.getElementById('schedule-content');
    const allMatches = getAllMoroccoMatches();

    if (allMatches.length === 0) {
      container.innerHTML = '<div class="empty">Spielplan wird geladen…</div>';
      return;
    }

    // Gruppiere: Gruppenphase / KO-Phase nach Runden
    const groupMatches = allMatches.filter(function(m) { return !m.koMatchId; });
    const koMatches = allMatches.filter(function(m) { return m.koMatchId; });

    let html = '';

    if (groupMatches.length > 0) {
      html += '<div class="schedule-group">';
      html += '<div class="schedule-group-title">▸ MAROKKOS GRUPPENPHASE 🇲🇦</div>';
      groupMatches.forEach(function(m) { html += renderMatchCard(m); });
      html += '</div>';
    }

    // K.O.-Phase nach Runden gruppieren
    const koRounds = [
      { key: 'round_of_16', label: '▸ ACHTELFINALE', waiting: 'wenn alle Gruppensieger feststehen (~25. Juni)' },
      { key: 'quarter', label: '▸ VIERTELFINALE', waiting: 'wenn alle Achtelfinale gespielt sind' },
      { key: 'semi', label: '▸ HALBFINALE', waiting: 'wenn alle Viertelfinale gespielt sind' },
      { key: 'final', label: '▸ FINALE 🏆', waiting: 'wenn die Halbfinale gespielt sind' }
    ];

    let anyKoVisible = false;
    koRounds.forEach(function(r) {
      const matchesInRound = koMatches.filter(function(m) { return m.roundKey === r.key; });
      if (matchesInRound.length > 0) {
        anyKoVisible = true;
        html += '<div class="schedule-group">';
        html += '<div class="schedule-group-title">' + r.label + '</div>';
        matchesInRound.forEach(function(m) { html += renderMatchCard(m); });
        html += '</div>';
      }
    });

    // Hinweis wenn noch keine K.O.-Spiele freigeschaltet sind
    if (!anyKoVisible) {
      html += '<div class="schedule-group">';
      html += '<div class="schedule-group-title">▸ K.O.-PHASE</div>';
      html += '<div class="empty" style="padding:20px 16px;">';
      html += '⏳ <strong>K.O.-Spiele werden freigeschaltet</strong>, sobald die Paarungen feststehen.<br><br>';
      html += '<span style="font-size:0.78rem; color:var(--text-muted);">';
      html += 'Achtelfinale: <strong>~25. Juni</strong> (nach Gruppenphase)<br>';
      html += 'Viertel-, Halb- &amp; Finale: jeweils nach der vorherigen Runde<br><br>';
      if (isAdmin) {
        html += '<span style="color:var(--gold);">Als Admin: Trage im Bracket-Tab die Gruppensieger ein, um die Achtelfinale-Paarungen freizuschalten.</span>';
      } else {
        html += 'Der Admin schaltet die Spiele frei, sobald die FIFA die Paarungen bestätigt hat.';
      }
      html += '</span>';
      html += '</div>';
      html += '</div>';
    }

    container.innerHTML = html;
    attachTippHandlers();
  }

  function renderMatchCard(match) {
    const status = getMatchStatus(match);
    const locked = isTippLocked(match);
    const result = state.results[match.id];
    const myTipp = currentUserId && state.tipps[match.id] ? state.tipps[match.id][currentUserId] : null;

    const teamAisMar = match.teamA.code === 'MAR';
    const teamBisMar = match.teamB.code === 'MAR';

    let statusBadge = '';
    if (status === 'live') statusBadge = '<span class="match-status status-live"><span class="live-blip"></span>LIVE</span>';
    else if (status === 'finished') statusBadge = '<span class="match-status status-finished">ENDE</span>';
    else if (status === 'finished_no_result') statusBadge = '<span class="match-status status-upcoming">BEENDET</span>';
    else statusBadge = '<span class="match-status status-upcoming">UPCOMING</span>';

    let scoreHtml;
    if (result) {
      scoreHtml = '<div class="match-score">' + result.a + '<span class="sep">:</span>' + result.b + '</div>';
    } else {
      scoreHtml = '<div class="match-score placeholder">– <span class="sep">:</span> –</div>';
    }

    let cardClass = 'match-card';
    if (teamAisMar || teamBisMar) cardClass += ' is-morocco';
    if (status === 'live') cardClass += ' live';
    if (status === 'finished') cardClass += ' finished';

    let html = '<div class="' + cardClass + '" data-match-id="' + match.id + '">';
    html += '<div class="match-head">';
    html += '<span class="match-stage">' + escapeHtml(match.stage) + '</span>';
    html += statusBadge;
    html += '</div>';

    html += '<div class="match-body">';
    html += '<div class="team-block ' + (teamAisMar ? 'is-morocco' : '') + '">';
    html += teamBadge(match.teamA);
    html += '<div class="team-info"><div class="team-info-name">' + escapeHtml(match.teamA.name) + '</div></div>';
    html += '</div>';

    html += '<div class="match-score-area">' + scoreHtml + '</div>';

    html += '<div class="team-block away ' + (teamBisMar ? 'is-morocco' : '') + '">';
    html += teamBadge(match.teamB);
    html += '<div class="team-info"><div class="team-info-name">' + escapeHtml(match.teamB.name) + '</div></div>';
    html += '</div>';
    html += '</div>'; // match-body

    // Meta-Bereich (Datum + Venue)
    html += '<div class="match-meta-bottom">';
    if (match.kickoff) {
      html += '<span>' + formatKickoff(match.kickoff) + '</span>';
    } else if (match.isKo) {
      html += '<span style="color:var(--text-muted);">Anpfiff offen' + (isAdmin ? ' (im Bracket eintragen)' : '') + '</span>';
    } else {
      html += '<span>Termin offen</span>';
    }
    html += '<span>' + escapeHtml(match.venue || '') + '</span>';
    html += '</div>';

    // Tipp-Bereich
    html += '<div class="match-tipp-area">';

    // Prüfe: Bei K.O.-Spielen müssen BEIDE Teams feststehen, um zu tippen
    const koTeamsPending = match.isKo && match.bothTeamsFinal === false;

    if (!currentUserId) {
      html += '<div class="lock-msg">Bitte zuerst anmelden, um zu tippen.</div>';
    } else if (koTeamsPending) {
      // Eine Mannschaft steht noch nicht fest → Tipp-Eingabe sperren
      html += '<div class="lock-msg">⏳ Tippen möglich, sobald <strong>beide Mannschaften</strong> feststehen</div>';
    } else if (locked) {
      // Sperre — nur Anzeige
      if (myTipp) {
        const points = result ? calcPoints(myTipp, result) : null;
        html += '<div class="my-tipp-display">';
        html += '<span class="label">Dein Tipp 🔒</span>';
        html += '<span class="value">' + myTipp.a + ' : ' + myTipp.b;
        if (points !== null) {
          html += '<span class="points-badge ' + (points === 0 ? 'zero' : '') + '">' + points + 'P</span>';
        }
        html += '</span>';
        html += '</div>';
      } else {
        html += '<div class="lock-msg">🔒 Tippen geschlossen — kein Tipp abgegeben</div>';
      }
    } else {
      // Tipp-Eingabe (eigene Tipps kann jeder ändern, fremde nur Admin)
      const tippA = myTipp ? myTipp.a : '';
      const tippB = myTipp ? myTipp.b : '';
      html += '<div class="match-tipp-input">';
      html += '<input class="mini-input" type="number" min="0" max="20" placeholder="?" value="' + tippA + '" data-tipp-input="a" data-match="' + match.id + '">';
