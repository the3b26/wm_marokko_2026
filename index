      saveBtn.addEventListener('click', async function() {
        document.querySelectorAll('[data-group]').forEach(function(input) {
          const g = input.getAttribute('data-group');
          const r = input.getAttribute('data-rank');
          if (!state.bracket.groups[g]) state.bracket.groups[g] = {};
          state.bracket.groups[g][r] = input.value.trim().toUpperCase();
        });
        await saveAndSync();
        showToast('Gruppen gespeichert');
