<div class="toast" id="toast">Gespeichert</div>

<script>
(function() {
  'use strict';

  // ═══════════════════════════════════════════════════════════
  // ─── KONFIGURATION (HIER ANPASSEN!) ────────────────────────
  // ═══════════════════════════════════════════════════════════
  const CONFIG = {
    // JSONBin: Gehe auf https://jsonbin.io → registrieren → Bin erstellen → ID + API-Key kopieren
    binId: '6a0b082a11c8435a0d445d93',          // z.B. '6745abc123def456789'
    apiKey: '$2a$10$SNKLHtEmiwyuvqgWUvI2YuR5y2OEMYDquDDMv3LGZmVEi5j.SX/Rm',         // z.B. '$2a$10$...'

    // Dein Admin-Code (hier ändern!)
    adminCode: 'ABUBE1991',

    // Familienhalle (für Standort)
    venue: 'Familienhalle Sabraoui',
  };

  // ═══════════════════════════════════════════════════════════
  // ─── WM-DATEN (Spielplan + K.O. Bracket) ───────────────────
  // ═══════════════════════════════════════════════════════════

  // Marokkos Gruppenspiele (Datum/Zeit in MESZ deutscher Zeit)
  // Quelle: offizieller FIFA-Spielplan WM 2026
  const MOROCCO_GROUP_MATCHES = [
    {
      id: 'group_1',
      stage: 'Gruppe C · Spieltag 1',
      teamA: { code: 'BRA', name: 'Brasilien', short: 'BRA', flag: '🇧🇷' },
      teamB: { code: 'MAR', name: 'Marokko', short: 'MAR', flag: '🇲🇦' },
      kickoff: '2026-06-14T00:00:00+02:00',
      venue: 'MetLife Stadium, New York'
    },
    {
      id: 'group_2',
      stage: 'Gruppe C · Spieltag 2',
      teamA: { code: 'SCO', name: 'Schottland', short: 'SCO', flag: '' },
      teamB: { code: 'MAR', name: 'Marokko', short: 'MAR', flag: '🇲🇦' },
      kickoff: '2026-06-20T00:00:00+02:00',
      venue: 'Gillette Stadium, Boston'
    },
    {
      id: 'group_3',
      stage: 'Gruppe C · Spieltag 3',
      teamA: { code: 'MAR', name: 'Marokko', short: 'MAR', flag: '🇲🇦' },
      teamB: { code: 'HAI', name: 'Haiti', short: 'HAI', flag: '🇭🇹' },
      kickoff: '2026-06-25T00:00:00+02:00',
      venue: 'Mercedes-Benz Stadium, Atlanta'
    },
  ];

  // K.O.-Runde: 32 Sechzehntelfinale-Plätze (Platzhalter werden befüllt sobald Gruppen entschieden)
  // Marokkos Gruppe C: C1 = Gruppensieger, C2 = Zweiter, C3 = Dritter (falls beste Dritte)
  // Vereinfacht: wir zeigen alle 16 Achtelfinal-Paarungen
  const BRACKET_TEMPLATE = {
    round_of_32: [
      // 16 Achtelfinale-Paarungen (16er-Finale gemäß FIFA Spielplan WM 2026 Modus)
      // Vereinfacht für unsere Familie: nur die wichtigsten K.O.-Spiele
    ],
    round_of_16: [
      { id: 'r16_1', label: 'Achtelfinale 1', teamA: 'A1', teamB: 'B2' },
      { id: 'r16_2', label: 'Achtelfinale 2', teamA: 'C1', teamB: 'D2' },
      { id: 'r16_3', label: 'Achtelfinale 3', teamA: 'E1', teamB: 'F2' },
      { id: 'r16_4', label: 'Achtelfinale 4', teamA: 'G1', teamB: 'H2' },
      { id: 'r16_5', label: 'Achtelfinale 5', teamA: 'B1', teamB: 'A2' },
      { id: 'r16_6', label: 'Achtelfinale 6', teamA: 'D1', teamB: 'C2' },
      { id: 'r16_7', label: 'Achtelfinale 7', teamA: 'F1', teamB: 'E2' },
      { id: 'r16_8', label: 'Achtelfinale 8', teamA: 'H1', teamB: 'G2' },
    ],
    quarter: [
      { id: 'qf_1', label: 'Viertelfinale 1', sourceA: 'r16_1', sourceB: 'r16_2' },
      { id: 'qf_2', label: 'Viertelfinale 2', sourceA: 'r16_3', sourceB: 'r16_4' },
      { id: 'qf_3', label: 'Viertelfinale 3', sourceA: 'r16_5', sourceB: 'r16_6' },
      { id: 'qf_4', label: 'Viertelfinale 4', sourceA: 'r16_7', sourceB: 'r16_8' },
    ],
    semi: [
      { id: 'sf_1', label: 'Halbfinale 1', sourceA: 'qf_1', sourceB: 'qf_2' },
      { id: 'sf_2', label: 'Halbfinale 2', sourceA: 'qf_3', sourceB: 'qf_4' },
    ],
    final: [
      { id: 'final', label: 'Finale', sourceA: 'sf_1', sourceB: 'sf_2' },
    ]
  };

  // ═══════════════════════════════════════════════════════════
  // ─── STATE & STORAGE ───────────────────────────────────────
  // ═══════════════════════════════════════════════════════════

  const LOCAL_KEY = 'sabraoui_wm2026_v1';

  const defaultState = {
    users: {},        // { userId: { name, joinedAt } }
    tipps: {},        // { matchId: { userId: { mar, opp, ts } } }
    results: {},      // { matchId: { mar/A, opp/B, setBy, ts } }   - nur Admin
    bracket: {        // K.O.-Runde Ergebnisse
      groups: {       // Gruppensieger pro Gruppe (Admin trägt ein)
        A: {}, B: {}, C: {}, D: {}, E: {}, F: {}, G: {}, H: {}, I: {}, J: {}, K: {}, L: {}
      },
      ko: {}          // { matchId: { teamA, teamB, scoreA, scoreB, winner } }
    },
    meta: {
      lastUpdated: 0,
      version: 1
    }
  };

  let state = JSON.parse(JSON.stringify(defaultState));
  let currentUserId = null;
  let isAdmin = false;
  let isSyncing = false;
  let pendingSave = false;

  // Lokale Settings (pro Gerät, nicht synchronisiert)
  function loadLocal() {
    try {
      const raw = localStorage.getItem(LOCAL_KEY);
      if (!raw) return {};
      return JSON.parse(raw);
    } catch (e) { return {}; }
  }

  function saveLocal(obj) {
    try { localStorage.setItem(LOCAL_KEY, JSON.stringify(obj)); } catch (e) {}
  }

  // ═══════════════════════════════════════════════════════════
  // ─── JSONBIN SYNC ──────────────────────────────────────────
  // ═══════════════════════════════════════════════════════════

  function hasJsonbin() {
    return CONFIG.binId && CONFIG.apiKey;
  }

  function setSyncStatus(status, text) {
    const dot = document.getElementById('sync-dot');
    const txt = document.getElementById('sync-text');
    dot.className = 'sync-dot ' + status;
    txt.textContent = text;
  }

  async function fetchFromCloud() {
    if (!hasJsonbin()) return null;
    setSyncStatus('syncing', 'LÄDT…');
    try {
      const res = await fetch('https://api.jsonbin.io/v3/b/' + CONFIG.binId + '/latest', {
        headers: { 'X-Master-Key': CONFIG.apiKey }
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      const remoteState = data.record;
      // Sanitize / merge
      if (remoteState && remoteState.meta) {
        state = mergeState(state, remoteState);
      }
      setSyncStatus('online', 'LIVE');
      return state;
    } catch (e) {
      console.error('Cloud fetch failed', e);
      setSyncStatus('error', 'OFFLINE');
      return null;
    }
  }

  async function pushToCloud() {
    if (!hasJsonbin()) {
      setSyncStatus('error', 'KEIN BIN');
      return;
    }
    if (isSyncing) { pendingSave = true; return; }
    isSyncing = true;
    setSyncStatus('syncing', 'SPEICHERT…');
    state.meta.lastUpdated = Date.now();
    try {
      const res = await fetch('https://api.jsonbin.io/v3/b/' + CONFIG.binId, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          'X-Master-Key': CONFIG.apiKey
        },
        body: JSON.stringify(state)
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      setSyncStatus('online', 'LIVE');
    } catch (e) {
      console.error('Cloud push failed', e);
      setSyncStatus('error', 'FEHLER');
      showToast('Sync fehlgeschlagen', true);
    }
    isSyncing = false;
    if (pendingSave) { pendingSave = false; pushToCloud(); }
  }

  function mergeState(local, remote) {
    // Remote ist primary, aber wir behalten Struktur falls Felder fehlen
    return Object.assign({}, defaultState, remote, {
      users: remote.users || {},
      tipps: remote.tipps || {},
      results: remote.results || {},
      bracket: Object.assign({}, defaultState.bracket, remote.bracket || {}),
      meta: Object.assign({}, defaultState.meta, remote.meta || {})
    });
  }

  // Polling alle 15 Sekunden (für live sync)
  function startPolling() {
    setInterval(async function() {
      if (!isSyncing && hasJsonbin()) {
        await fetchFromCloud();
        renderAll();
      }
    }, 15000);
  }

  async function saveAndSync() {
    await pushToCloud();
    renderAll();
  }

  // ═══════════════════════════════════════════════════════════
  // ─── USER MANAGEMENT ───────────────────────────────────────
  // ═══════════════════════════════════════════════════════════

  function generateUserId() {
    return 'u_' + Date.now().toString(36) + '_' + Math.random().toString(36).slice(2, 7);
  }

  function initUser() {
    const local = loadLocal();
    if (local.userId && local.userName) {
      currentUserId = local.userId;
      // Stelle sicher, dass User auch im State ist (falls neuer Sync)
      if (!state.users[currentUserId]) {
        state.users[currentUserId] = { name: local.userName, joinedAt: Date.now() };
      }
      isAdmin = !!local.isAdmin;
      updateUserUI();
    } else {
      // Zeige Setup-Modal
      showUserModal();
    }
  }

  function updateUserUI() {
    const local = loadLocal();
    if (local.userName) {
      document.getElementById('user-name-display').innerHTML =
        escapeHtml(local.userName) +
        (isAdmin ? ' <span class="user-badge">ADMIN</span>' : '');
      document.getElementById('user-avatar').textContent = local.userName.slice(0, 1).toUpperCase();
    } else {
      document.getElementById('user-name-display').textContent = 'Nicht angemeldet';
      document.getElementById('user-avatar').textContent = '?';
    }
    document.getElementById('btn-admin-login').style.display = isAdmin ? 'none' : '';
    document.getElementById('btn-admin-logout').style.display = isAdmin ? '' : 'none';

    // Top-Admin-Button updaten
    const topBtn = document.getElementById('btn-admin-login-top');
    if (topBtn) {
      topBtn.classList.toggle('is-admin', isAdmin);
      topBtn.textContent = isAdmin ? '👑' : '🔐';
      topBtn.title = isAdmin ? 'Admin aktiv (klick zum Abmelden)' : 'Admin-Modus aktivieren';
    }
  }

  function showUserModal() {
    const local = loadLocal();
    document.getElementById('input-username').value = local.userName || '';
    document.getElementById('modal-user').classList.add('show');
    setTimeout(function() { document.getElementById('input-username').focus(); }, 100);
  }

  document.getElementById('btn-save-user').addEventListener('click', async function() {
    const name = document.getElementById('input-username').value.trim();
    if (!name) { showToast('Bitte Name eingeben', true); return; }

    const local = loadLocal();
    if (!local.userId) local.userId = generateUserId();
    local.userName = name;
    saveLocal(local);

    currentUserId = local.userId;
    state.users[currentUserId] = { name: name, joinedAt: state.users[currentUserId] ? state.users[currentUserId].joinedAt : Date.now() };

    document.getElementById('modal-user').classList.remove('show');
    updateUserUI();
    await saveAndSync();
    showToast('Willkommen ' + name + '! 🇲🇦');
  });

  document.getElementById('btn-user-settings').addEventListener('click', showUserModal);

  // ═══════════════════════════════════════════════════════════
  // ─── ADMIN MANAGEMENT ──────────────────────────────────────
  // ═══════════════════════════════════════════════════════════

  document.getElementById('btn-admin-login').addEventListener('click', function() {
    document.getElementById('input-admin-code').value = '';
    document.getElementById('modal-admin').classList.add('show');
    setTimeout(function() { document.getElementById('input-admin-code').focus(); }, 100);
  });

  // Top-Admin-Button: Toggle Anmelden / Abmelden
  document.getElementById('btn-admin-login-top').addEventListener('click', function() {
    if (isAdmin) {
      if (confirm('Admin-Modus verlassen?')) {
        isAdmin = false;
        const local = loadLocal();
        local.isAdmin = false;
        saveLocal(local);
        updateUserUI();
        renderAll();
        showToast('Admin-Modus verlassen');
      }
    } else {
      document.getElementById('input-admin-code').value = '';
      document.getElementById('modal-admin').classList.add('show');
      setTimeout(function() { document.getElementById('input-admin-code').focus(); }, 100);
    }
  });

  document.getElementById('btn-admin-cancel').addEventListener('click', function() {
    document.getElementById('modal-admin').classList.remove('show');
  });

  document.getElementById('btn-admin-submit').addEventListener('click', function() {
    const code = document.getElementById('input-admin-code').value;
    if (code === CONFIG.adminCode) {
      isAdmin = true;
      const local = loadLocal();
      local.isAdmin = true;
      saveLocal(local);
      document.getElementById('modal-admin').classList.remove('show');
      updateUserUI();
      renderAll();
      showToast('Admin-Modus aktiviert 👑');
    } else {
      showToast('Falscher Code', true);
    }
  });

  // Enter-Taste im Admin-Code-Feld
  document.getElementById('input-admin-code').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      document.getElementById('btn-admin-submit').click();
    }
  });
  // Enter-Taste im User-Name-Feld
  document.getElementById('input-username').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      document.getElementById('btn-save-user').click();
    }
  });

  document.getElementById('btn-admin-logout').addEventListener('click', function() {
    isAdmin = false;
    const local = loadLocal();
    local.isAdmin = false;
    saveLocal(local);
    updateUserUI();
    renderAll();
    showToast('Admin-Modus verlassen');
  });

  // ═══════════════════════════════════════════════════════════
  // ─── TABS ──────────────────────────────────────────────────
  // ═══════════════════════════════════════════════════════════

  document.getElementById('tabs').addEventListener('click', function(e) {
    const btn = e.target.closest('.tab');
    if (!btn) return;
    const tab = btn.getAttribute('data-tab');
    document.querySelectorAll('.tab').forEach(function(t) { t.classList.toggle('active', t === btn); });
    document.querySelectorAll('.tab-content').forEach(function(c) {
      c.classList.toggle('active', c.getAttribute('data-content') === tab);
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // ═══════════════════════════════════════════════════════════
  // ─── SPIELPLAN RENDERING ───────────────────────────────────
  // ═══════════════════════════════════════════════════════════

  function getAllMoroccoMatches() {
    // Gruppenspiele Marokkos + ALLE K.O.-Spiele (auch ohne Marokko)
    const all = MOROCCO_GROUP_MATCHES.slice();
    const koMatches = getAllKoMatches();
    return all.concat(koMatches);
  }

  function getAllKoMatches() {
    // K.O.-Spiele werden gezeigt, wenn MINDESTENS EIN Team feststeht.
    // Tippen aber erst möglich, wenn BEIDE Teams feststehen (Logik in renderMatchCard).
    const result = [];
    const allRounds = ['round_of_16', 'quarter', 'semi', 'final'];
    const stageLabels = {
      round_of_16: 'Achtelfinale',
      quarter: 'Viertelfinale',
      semi: 'Halbfinale',
      final: 'Finale'
    };
    allRounds.forEach(function(round) {
      BRACKET_TEMPLATE[round].forEach(function(m) {
        const resolved = resolveBracketTeams(m);
        const teamAOk = resolved.teamA && /^[A-Z]{3}$/.test(resolved.teamA);
        const teamBOk = resolved.teamB && /^[A-Z]{3}$/.test(resolved.teamB);

        // Mindestens ein Team muss feststehen, sonst gar nicht zeigen
        if (!teamAOk && !teamBOk) return;

        const koState = state.bracket.ko[m.id] || {};
        const teamACode = teamAOk ? resolved.teamA : (m.teamA || 'TBD');
        const teamBCode = teamBOk ? resolved.teamB : (m.teamB || 'TBD');

        result.push({
          id: 'ko_' + m.id,
          koMatchId: m.id,
          stage: stageLabels[round] + ' · ' + m.label,
          teamA: codeToTeam(teamACode),
          teamB: codeToTeam(teamBCode),
          kickoff: koState.kickoff || null,
          venue: koState.venue || '',
          isKo: true,
          roundKey: round,
          // Diese Flag wird in renderMatchCard ausgewertet, um Tippen zu erlauben/sperren
          bothTeamsFinal: teamAOk && teamBOk
        });
      });
    });
    return result;
  }

  // Beibehalten für Stat-Anzeigen
  function getKoMatchesWithMorocco() {
    return getAllKoMatches().filter(function(m) {
      return isMorocco(m.teamA.code) || isMorocco(m.teamB.code);
    });
  }

  function isMorocco(teamCode) {
    return teamCode === 'MAR' || teamCode === 'C2' || teamCode === 'C1' || teamCode === 'C3';
  }

  // Echte SVG-Flaggen (funktionieren auf JEDEM Gerät, auch Windows)
  // Vereinfachte aber erkennbare Versionen der Nationalflaggen
  const COUNTRY_FLAGS = {
